# Server
PORT=3000

# --- AWS Secrets Manager (production) ---
# Name or ARN of the secret holding all sensitive values (see README for the
# expected JSON shape). When set, the values below are fetched at startup and
# override the corresponding env vars. Leave unset for local development.
AWS_SECRET_ID=
AWS_REGION=ap-southeast-1

# --- Local-development fallback secrets ---
# Only used when AWS_SECRET_ID is not set. In production these live in AWS
# Secrets Manager instead — see AWS_SECRET_ID above.
WEBHOOK_SECRET=your_bitbucket_webhook_secret

# Single Atlassian API token (https://id.atlassian.com/manage-profile/security/api-tokens)
# used for every Bitbucket repo this account can access, and for cloning the
# product-blueprint skills repo. No more per-repo tokens.
ATLASSIAN_EMAIL=you@example.com
ATLASSIAN_API_TOKEN=your_atlassian_api_token

# --- AI provider: gemini | anthropic (both served through Google Vertex AI) ---
AI_PROVIDER=gemini

# Google Cloud project/region hosting the Vertex AI endpoints for Claude and Gemini.
# Auth is via Application Default Credentials — gcloud auth application-default
# login locally, or a service account key delivered through AWS Secrets Manager
# in production (see gcpServiceAccountJson in the README).
GCP_PROJECT_ID=your-gcp-project-id
GCP_LOCATION=us-central1

# Bitbucket workspace
BITBUCKET_WORKSPACE=ntuclink

# Local path to cache the cloned product-blueprint repo
SKILLS_REPO_PATH=./skills-repo
